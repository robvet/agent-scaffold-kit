{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Cleanup",
            "type": "shell",
            "command": "./cleanup.ps1",
            "options": {
                "cwd": "${workspaceFolder}/src"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Backend",
            "type": "shell",
            "command": "bash ./scripts/start-backend.sh",
            "options": {
                "cwd": "${workspaceFolder}/src"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "servers"
            },
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "Frontend",
            "type": "shell",
            "command": "bash ./scripts/start-frontend.sh",
            "options": {
                "cwd": "${workspaceFolder}/src"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "servers"
            },
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "Start All",
            "dependsOn": [
                "Backend",
                "Frontend"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Open Browser",
            "type": "shell",
            "command": "Start-Sleep -Seconds 2; Start-Process 'http://127.0.0.1:8010/docs'",
            "windows": {
                "command": "powershell.exe",
                "args": [
                    "-Command",
                    "Start-Sleep -Seconds 2; Start-Process 'http://127.0.0.1:8010/docs'"
                ]
            },
            "problemMatcher": []
        }
    ]
}